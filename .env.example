# Supabase (existing staffarmy-prod project — add new tables, do NOT create new project)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Brenda DB — READ ONLY from Agent OS
BRENDA_DATABASE_URL=

# Redis (existing Railway Redis)
REDIS_URL=

# Anthropic (T2-HIGH + T3-FULL agents)
ANTHROPIC_API_KEY=

# DashScope (T1-EXEC agents via Qwen3 + AgentWorld training)
DASHSCOPE_API_KEY=

# AWS S3 (existing reelmax-content-vault bucket, new paths only)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=reelmax-content-vault
AWS_REGION=us-east-2

# reelmax-portal internal URL (GHL + GeeLark routing — no new connector service)
REELMAX_INTERNAL_URL=https://reelmax-portal.railway.internal

# GHL
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_WEBHOOK_SECRET=

# GeeLark
GEELARK_API_KEY=
GEELARK_API_URL=

# Qwen / DashScope (Phase 1 — API access, no GPU needed)
QWEN_API_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model endpoints (Phase 1: all point to DashScope base)
QWEN_EXECUTOR_URL=${QWEN_API_BASE}      # T1-EXEC tasks → Qwen3-14B
QWEN_RESEARCH_URL=${QWEN_API_BASE}      # Research/RAG → Qwen3-32B
QWEN_AGENTWORLD_URL=${QWEN_API_BASE}    # AgentWorld → Qwen-AgentWorld-35B
QWEN_MULTILINGUAL_URL=${QWEN_API_BASE}  # Portuguese/Spanish → Qwen3-14B

# Qwen model names per task type (update from current DashScope docs)
QWEN_EXECUTOR_MODEL=qwen-plus
QWEN_RESEARCH_MODEL=qwen-max
QWEN_AGENTWORLD_MODEL=qwen-agentworld-35b-a3b
QWEN_MULTILINGUAL_MODEL=qwen-plus

# Phase 2 migration: when DashScope cost exceeds $130/mo, swap AgentWorld to Railway H100:
# QWEN_AGENTWORLD_URL=https://qwen-agentworld.railway.internal:8003/v1
# QWEN_AGENTWORLD_MODEL=Qwen/Qwen-AgentWorld-35B-A3B
# No other code changes needed.

# Model routing
DEFAULT_T1_MODEL=qwen
DEFAULT_T2_MODEL=claude
DEFAULT_T3_MODEL=claude
QWEN_THINKING_THRESHOLD=0.7

# Agent OS config
PORT=3001
FRONTEND_URL=https://agent-os.vercel.app
API_URL=https://agent-os-api.railway.app
JWT_SECRET=
INTERNAL_API_KEY=

# Training + improvement config
TRAINING_PASS_THRESHOLD=95
PRODUCTION_CONFIRMATION_DAYS=7
IMPROVEMENT_CRON=0 2 * * *
MIN_RUNS_FOR_ANALYSIS=20
SUCCESS_RATE_ALERT_THRESHOLD=70
CONSECUTIVE_FAILURE_ALERT=3
