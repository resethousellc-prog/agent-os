# Supabase (existing staffarmy-prod project — add new tables, do NOT create new project)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Brenda DB — READ ONLY from Agent OS
BRENDA_DATABASE_URL=

# Redis (existing Railway Redis)
REDIS_URL=

# Anthropic (T2-HIGH + T3-FULL agents)
ANTHROPIC_API_KEY=

# DashScope (T1-EXEC agents via Qwen3 + AgentWorld training)
DASHSCOPE_API_KEY=

# AWS S3 (existing reelmax-content-vault bucket, new paths only)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=reelmax-content-vault
AWS_REGION=us-east-2

# reelmax-portal internal URL (GHL + GeeLark routing — no new connector service)
REELMAX_INTERNAL_URL=https://reelmax-portal.railway.internal

# GHL
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_WEBHOOK_SECRET=

# GeeLark
GEELARK_API_KEY=
GEELARK_API_URL=

# Qwen via Groq (Phase 1 — OpenAI-compatible API, no GPU needed)
# NOTE: qwen.js reads the bearer token from DASHSCOPE_API_KEY — set it to your Groq API key.
QWEN_API_BASE=https://api.groq.com/openai/v1

# Model endpoints (Phase 1: all point to the Groq base)
QWEN_EXECUTOR_URL=${QWEN_API_BASE}      # T1-EXEC tasks
QWEN_RESEARCH_URL=${QWEN_API_BASE}      # Research/RAG
QWEN_AGENTWORLD_URL=${QWEN_API_BASE}    # AgentWorld simulation
QWEN_MULTILINGUAL_URL=${QWEN_API_BASE}  # Portuguese/Spanish

# Qwen model name on Groq (single model serves all task types in Phase 1)
QWEN_EXECUTOR_MODEL=qwen/qwen3.6-27b
QWEN_RESEARCH_MODEL=qwen/qwen3.6-27b
QWEN_AGENTWORLD_MODEL=qwen/qwen3.6-27b
QWEN_MULTILINGUAL_MODEL=qwen/qwen3.6-27b

# Phase 2 migration: when cost justifies it, swap AgentWorld to a self-hosted Railway H100:
# QWEN_AGENTWORLD_URL=https://qwen-agentworld.railway.internal:8003/v1
# QWEN_AGENTWORLD_MODEL=Qwen/Qwen-AgentWorld-35B-A3B
# No other code changes needed.

# Model routing
DEFAULT_T1_MODEL=qwen
DEFAULT_T2_MODEL=claude
DEFAULT_T3_MODEL=claude
QWEN_THINKING_THRESHOLD=0.7

# Agent OS config
PORT=3001
FRONTEND_URL=https://agent-os.vercel.app
API_URL=https://agent-os-api.railway.app
JWT_SECRET=
INTERNAL_API_KEY=

# Training + improvement config
TRAINING_PASS_THRESHOLD=95
PRODUCTION_CONFIRMATION_DAYS=7
IMPROVEMENT_CRON=0 2 * * *
MIN_RUNS_FOR_ANALYSIS=20
SUCCESS_RATE_ALERT_THRESHOLD=70
CONSECUTIVE_FAILURE_ALERT=3
